#!/usr/bin/env python3
"""
Kart Dashboard  —  Tesla Style  —  Raspberry Pi 4  |  800x480
Sensors: MPU-6050 (I2C), INA219 (I2C), Hall Effect, HC-SR04 x2, Buzzer, USB Camera
"""

import pygame
import sys
import math
import time
import threading

# ── Hardware detection ────────────────────────────────────────────────────────
DEMO_MODE = False
try:
    import smbus2
    import RPi.GPIO as GPIO
    import cv2
    HW_AVAILABLE = True
except ImportError:
    HW_AVAILABLE = False
    DEMO_MODE = True
    print("[INFO] Running in DEMO mode — hardware libs not found")

# ══════════════════════════════════════════════════════════════════════════════
#  CONFIGURATION  — edit these to match your build
# ══════════════════════════════════════════════════════════════════════════════
I2C_BUS         = 1

# MPU-6050
MPU_ADDR        = 0x68

# INA219  (default address = 0x40)
INA219_ADDR     = 0x40
INA219_REG_CFG  = 0x00
INA219_REG_BUS  = 0x02
INA219_REG_CUR  = 0x04
INA219_REG_CAL  = 0x05
# Calibration: for 0.1-ohm shunt, +-3.2 A range
# Current LSB = max_current / 32768 = 0.0001 A (100 uA)
INA219_CAL_VAL  = 4096
INA219_CUR_LSB  = 0.0001

# Battery thresholds (3S LiPo default — change for your pack)
BATT_FULL_V     = 12.6
BATT_EMPTY_V    = 9.9

# GPIO (BCM numbering)
HALL_PIN        = 17
MAGNET_COUNT    = 4
TRIG_FRONT      = 23
ECHO_FRONT      = 24
TRIG_BACK       = 27
ECHO_BACK       = 22
BUZZER_PIN      = 18

WHEEL_CIRC_M    = 0.628      # pi * wheel_diameter_metres
CAMERA_INDEX    = 0          # /dev/video0

# ══════════════════════════════════════════════════════════════════════════════
#  SHARED STATE
# ══════════════════════════════════════════════════════════════════════════════
state = {
    "speed_kph":    0.0,
    "roll_deg":     0.0,
    "pitch_deg":    0.0,
    "yaw_deg":      0.0,
    "dist_front":   999,
    "dist_back":    999,
    "batt_pct":     100,
    "batt_v":       12.6,
    "batt_amps":    0.0,
    "batt_mw":      0.0,
    "camera_frame": None,
}
state_lock = threading.Lock()

# ══════════════════════════════════════════════════════════════════════════════
#  INA219 DRIVER  (pure smbus2, no external lib needed)
# ══════════════════════════════════════════════════════════════════════════════
class INA219:
    def __init__(self, bus, addr=INA219_ADDR):
        self.bus  = bus
        self.addr = addr
        self._write(INA219_REG_CAL, INA219_CAL_VAL)
        # Config: 32V bus range, +/-320mV shunt, 12-bit ADC, continuous
        self._write(INA219_REG_CFG, 0x1FFF)

    def _write(self, reg, val):
        self.bus.write_i2c_block_data(self.addr, reg,
                                      [(val >> 8) & 0xFF, val & 0xFF])

    def _read(self, reg):
        d = self.bus.read_i2c_block_data(self.addr, reg, 2)
        return (d[0] << 8) | d[1]

    def voltage(self):
        """Bus voltage in Volts"""
        return (self._read(INA219_REG_BUS) >> 3) * 0.004

    def current_A(self):
        """Current in Amperes (signed)"""
        raw = self._read(INA219_REG_CUR)
        if raw > 32767:
            raw -= 65536
        return raw * INA219_CUR_LSB

    def power_mW(self):
        """Power in milliWatts"""
        return self._read(0x03) * 2.0

# ══════════════════════════════════════════════════════════════════════════════
#  GPIO / I2C SETUP
# ══════════════════════════════════════════════════════════════════════════════
def setup_gpio():
    GPIO.setmode(GPIO.BCM)
    GPIO.setwarnings(False)
    GPIO.setup(HALL_PIN,   GPIO.IN,  pull_up_down=GPIO.PUD_UP)
    GPIO.setup(TRIG_FRONT, GPIO.OUT); GPIO.output(TRIG_FRONT, False)
    GPIO.setup(ECHO_FRONT, GPIO.IN)
    GPIO.setup(TRIG_BACK,  GPIO.OUT); GPIO.output(TRIG_BACK, False)
    GPIO.setup(ECHO_BACK,  GPIO.IN)
    GPIO.setup(BUZZER_PIN, GPIO.OUT)

def _mpu_read(bus):
    def rw(r):
        h = bus.read_byte_data(MPU_ADDR, r)
        l = bus.read_byte_data(MPU_ADDR, r + 1)
        v = (h << 8) + l
        return v - 65536 if v >= 0x8000 else v
    ax = rw(0x3B) / 16384.0
    ay = rw(0x3D) / 16384.0
    az = rw(0x3F) / 16384.0
    gx = rw(0x43) / 131.0
    gy = rw(0x45) / 131.0
    gz = rw(0x47) / 131.0
    return ax, ay, az, gx, gy, gz

def _ultrasonic(trig, echo):
    GPIO.output(trig, True)
    time.sleep(1e-5)
    GPIO.output(trig, False)
    t0 = time.time()
    while GPIO.input(echo) == 0:
        if time.time() - t0 > 0.04:
            return 999
    t1 = time.time()
    while GPIO.input(echo) == 1:
        if time.time() - t1 > 0.04:
            return 999
    return round((time.time() - t1) * 17150, 1)

# ══════════════════════════════════════════════════════════════════════════════
#  SENSOR THREADS
# ══════════════════════════════════════════════════════════════════════════════
def thread_speed():
    pulses = []
    def cb(ch):
        pulses.append(time.time())
        if len(pulses) > MAGNET_COUNT * 4:
            pulses.pop(0)
    GPIO.add_event_detect(HALL_PIN, GPIO.FALLING, callback=cb, bouncetime=5)
    while True:
        time.sleep(0.2)
        now = time.time()
        recent = [t for t in pulses if now - t < 1.0]
        if len(recent) >= 2:
            ivs = [recent[i+1] - recent[i] for i in range(len(recent)-1)]
            rps = 1.0 / (sum(ivs)/len(ivs) * MAGNET_COUNT)
            kph = rps * WHEEL_CIRC_M * 3.6
        else:
            kph = 0.0
        with state_lock:
            state["speed_kph"] = min(kph, 150.0)

def thread_imu():
    alpha = 0.96
    roll = pitch = yaw = 0.0
    last_t = time.time()
    bus = smbus2.SMBus(I2C_BUS)
    bus.write_byte_data(MPU_ADDR, 0x6B, 0)  # wake up
    while True:
        ax, ay, az, gx, gy, gz = _mpu_read(bus)
        now = time.time(); dt = now - last_t; last_t = now
        ar = math.degrees(math.atan2(ay, az))
        ap = math.degrees(math.atan2(-ax, math.sqrt(ay**2 + az**2)))
        roll  = alpha*(roll  + gx*dt) + (1-alpha)*ar
        pitch = alpha*(pitch + gy*dt) + (1-alpha)*ap
        yaw  += gz * dt
        with state_lock:
            state["roll_deg"]  = roll
            state["pitch_deg"] = pitch
            state["yaw_deg"]   = yaw % 360
        time.sleep(0.02)

def thread_ultrasonic():
    while True:
        df = _ultrasonic(TRIG_FRONT, ECHO_FRONT)
        db = _ultrasonic(TRIG_BACK,  ECHO_BACK)
        with state_lock:
            state["dist_front"] = df
            state["dist_back"]  = db
        time.sleep(0.09)

def thread_buzzer():
    while True:
        with state_lock:
            d = min(state["dist_front"], state["dist_back"])
        if d < 200:
            p = max(0.04, d / 1200.0)
            GPIO.output(BUZZER_PIN, True);  time.sleep(p * 0.35)
            GPIO.output(BUZZER_PIN, False); time.sleep(p * 0.65)
        else:
            GPIO.output(BUZZER_PIN, False)
            time.sleep(0.1)

def thread_camera():
    cap = cv2.VideoCapture(CAMERA_INDEX)
    cap.set(cv2.CAP_PROP_FRAME_WIDTH,  280)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 210)
    while True:
        ret, frame = cap.read()
        if ret:
            rgb  = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            surf = pygame.surfarray.make_surface(rgb.swapaxes(0, 1))
            with state_lock:
                state["camera_frame"] = surf
        time.sleep(0.033)

def thread_power():
    bus = smbus2.SMBus(I2C_BUS)
    ina = INA219(bus)
    while True:
        try:
            v   = ina.voltage()
            a   = ina.current_A()
            mw  = ina.power_mW()
            pct = int(((v - BATT_EMPTY_V) / (BATT_FULL_V - BATT_EMPTY_V)) * 100)
            pct = max(0, min(100, pct))
            with state_lock:
                state["batt_v"]    = v
                state["batt_amps"] = a
                state["batt_mw"]   = mw
                state["batt_pct"]  = pct
        except Exception:
            pass
        time.sleep(0.4)

# ══════════════════════════════════════════════════════════════════════════════
#  DEMO SIMULATION
# ══════════════════════════════════════════════════════════════════════════════
_dt = 0.0
def demo_tick():
    global _dt
    _dt += 0.025
    with state_lock:
        state["speed_kph"]  = 55 + 40*math.sin(_dt*0.28)
        state["roll_deg"]   = 18*math.sin(_dt*0.45)
        state["pitch_deg"]  = 12*math.sin(_dt*0.37 + 1)
        state["yaw_deg"]    = (_dt*15) % 360
        state["dist_front"] = max(8, 160 + 130*math.sin(_dt*0.62))
        state["dist_back"]  = max(8, 190 + 100*math.sin(_dt*0.51 + 2))
        state["batt_pct"]   = int(68 + 18*math.sin(_dt*0.08))
        state["batt_v"]     = 11.2 + 1.2*math.sin(_dt*0.08)
        state["batt_amps"]  = abs(6.5*math.sin(_dt*0.19))
        state["batt_mw"]    = state["batt_v"] * state["batt_amps"] * 1000

# ══════════════════════════════════════════════════════════════════════════════
#  COLOUR PALETTE  — Tesla: pure black, white, red accent
# ══════════════════════════════════════════════════════════════════════════════
W, H = 800, 480

C_BG    = (  7,   7,   7)
C_CARD  = ( 16,  16,  16)
C_LINE  = ( 36,  36,  36)
C_WHITE = (240, 240, 240)
C_G1    = (155, 155, 155)
C_G2    = ( 88,  88,  88)
C_RED   = (225,  55,  42)
C_ORG   = (230, 140,  20)
C_GRN   = ( 90, 205,  90)
C_BLU   = ( 75, 155, 255)

def lerp_c(a, b, t):
    return tuple(int(a[i] + (b[i]-a[i])*t) for i in range(3))

def dist_col(d):
    if d < 30:  return C_RED
    if d < 80:  return C_ORG
    if d < 160: return (200, 200, 55)
    return C_GRN

def batt_col(p):
    if p < 20: return C_RED
    if p < 40: return C_ORG
    return C_GRN

def txt(surf, text, font, color, x, y, anchor="center"):
    img = font.render(str(text), True, color)
    r   = img.get_rect()
    setattr(r, anchor, (x, y))
    surf.blit(img, r)

def vline(s, x, y1, y2): pygame.draw.line(s, C_LINE, (x, y1), (x, y2), 1)
def hline(s, y, x1, x2): pygame.draw.line(s, C_LINE, (x1, y), (x2, y), 1)

# ══════════════════════════════════════════════════════════════════════════════
#  STARTUP ANIMATION
#  Phase 1 (0.0-1.3s): "C" arc sweeps in with glowing leading dot
#  Phase 2 (1.3-2.3s): full "C" pulses, subtitle fades in
#  Phase 3 (2.3-3.4s): fade to black -> dashboard
# ══════════════════════════════════════════════════════════════════════════════
def run_startup(screen, f_sub):
    clock = pygame.time.Clock()
    t0    = time.time()
    CX, CY, R = W//2, H//2, 96
    # "C" arc: 300 degrees, open gap on right side
    # In pygame, angles go counter-clockwise; we want clockwise draw
    GAP_DEG  = 60                          # gap at the right
    START_A  = math.radians(GAP_DEG / 2)   # bottom-right
    END_A    = math.radians(360 - GAP_DEG/2) # top-right, going around

    def draw_C_arc(surf, progress, brightness=1.0):
        """progress: 0..1 — how much of the C arc to draw"""
        total = END_A - START_A           # ~300 deg in radians
        draw_to = START_A + total * progress

        # Draw in anti-aliased layers (glow)
        layers = [
            (26, 0.04), (18, 0.10), (10, 0.28), (5, 0.60), (2, 1.00),
        ]
        rect = pygame.Rect(CX-R, CY-R, R*2, R*2)
        for thick, am in layers:
            col = lerp_c(C_G2, C_WHITE, am * brightness)
            # pygame.draw.arc uses mathematical angles (CCW from east)
            # We want CW so we negate: draw from -(draw_to) to -(START_A)
            a1 = -draw_to
            a2 = -START_A
            if a2 - a1 > 0.01 or a1 - a2 > 0.01:
                pygame.draw.arc(surf, col, rect, a1, a2, thick)

        # Glowing leading dot
        if progress > 0.01:
            dot_ang = draw_to
            dx = CX + R * math.cos(-dot_ang)
            dy = CY + R * math.sin(-dot_ang)
            for rr, aa in [(22, 20), (14, 50), (8, 110), (4, 200)]:
                gs = pygame.Surface((rr*2, rr*2), pygame.SRCALPHA)
                pygame.draw.circle(gs, (*C_WHITE, aa), (rr, rr), rr)
                surf.blit(gs, (int(dx-rr), int(dy-rr)))

    while True:
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN and ev.key == pygame.K_ESCAPE:
                return

        t = time.time() - t0
        if t > 3.5:
            return

        screen.fill(C_BG)

        # ── Phase 1: draw arc ────────────────────────────────────────────
        if t < 1.3:
            progress = t / 1.3
            eased = progress * progress * (3 - 2*progress)   # smoothstep
            draw_C_arc(screen, eased, 1.0)

        # ── Phase 2: full arc + subtitle ────────────────────────────────
        elif t < 2.3:
            sub_t = (t - 1.3) / 1.0
            pulse = 0.88 + 0.12 * math.sin(t * 9)
            draw_C_arc(screen, 1.0, pulse)

            # "KART DASHBOARD" fade in
            if sub_t > 0.25:
                fa = min(255, int((sub_t - 0.25) / 0.5 * 255))
                si = pygame.font.SysFont("dejavusans", 18).render(
                        "KART DASHBOARD", True, C_G1)
                si.set_alpha(fa)
                screen.blit(si, si.get_rect(center=(CX, CY + R + 34)))

            if sub_t > 0.55:
                fa2 = min(255, int((sub_t - 0.55) / 0.35 * 255))
                vi = pygame.font.SysFont("dejavusans", 13).render(
                        "v2.0  |  INA219 + MPU-6050", True, C_G2)
                vi.set_alpha(fa2)
                screen.blit(vi, vi.get_rect(center=(CX, CY + R + 58)))

        # ── Phase 3: fade out ────────────────────────────────────────────
        else:
            fade_t = (t - 2.3) / 1.2
            draw_C_arc(screen, 1.0, 1.0 - fade_t)
            fade = pygame.Surface((W, H)); fade.fill(C_BG)
            fade.set_alpha(int(fade_t * 255))
            screen.blit(fade, (0, 0))

        pygame.display.flip()
        clock.tick(60)

# ══════════════════════════════════════════════════════════════════════════════
#  3-D CAR WIREFRAME
# ══════════════════════════════════════════════════════════════════════════════
_VERTS = [
    (-1.0,-0.3,-2.0),(1.0,-0.3,-2.0),(1.0,-0.3,2.0),(-1.0,-0.3,2.0),
    (-0.85,0.45,-1.4),(0.85,0.45,-1.4),(0.85,0.45,0.9),(-0.85,0.45,0.9),
    (-0.55,0.85,-0.7),(0.55,0.85,-0.7),(0.55,0.85,0.6),(-0.55,0.85,0.6),
    (0.0,0.05,-2.7),
]
_EDGES = [
    (0,1),(1,2),(2,3),(3,0),
    (4,5),(5,6),(6,7),(7,4),
    (8,9),(9,10),(10,11),(11,8),
    (0,4),(1,5),(2,6),(3,7),
    (4,8),(5,9),(6,10),(7,11),
    (0,12),(1,12),(12,4),(12,5),
]

def _rxv(v, a):
    ca,sa = math.cos(a),math.sin(a)
    return [(x, y*ca-z*sa, y*sa+z*ca) for x,y,z in v]
def _rzv(v, a):
    ca,sa = math.cos(a),math.sin(a)
    return [(x*ca-y*sa, x*sa+y*ca, z) for x,y,z in v]
def _proj(x, y, z, cx, cy):
    zo = z + 5.0 or 0.001
    return int(cx + x*170/zo), int(cy - y*170/zo)

def draw_car(surf, cx, cy, roll, pitch, sc=0.58):
    v = [(x*sc, y*sc, z*sc) for x,y,z in _VERTS]
    v = _rxv(v, math.radians(pitch))
    v = _rzv(v, math.radians(roll))
    pts = [_proj(*vi, cx, cy) for vi in v]
    for e in _EDGES:
        pygame.draw.line(surf, C_WHITE, pts[e[0]], pts[e[1]], 1)
    for i in range(4):
        pygame.draw.circle(surf, C_G2, pts[i], 5, 1)

# ══════════════════════════════════════════════════════════════════════════════
#  UI WIDGETS
# ══════════════════════════════════════════════════════════════════════════════
def draw_speed_arc(surf, cx, cy, R, speed, f_num, f_unit):
    MAX = 130
    # Track ring
    pygame.draw.arc(surf, C_LINE,
        pygame.Rect(cx-R, cy-R, R*2, R*2),
        math.radians(220), math.radians(500), 6)
    # Filled arc
    span = math.radians(280)
    fill = span * min(speed, MAX) / MAX
    if fill > 0.01:
        col = lerp_c(C_GRN, C_RED, min(speed, MAX)/MAX)
        pygame.draw.arc(surf, col,
            pygame.Rect(cx-R+2, cy-R+2, (R-2)*2, (R-2)*2),
            math.radians(220), math.radians(220)+fill, 6)
    # Tick marks
    for s in range(0, MAX+1, 20):
        a = math.radians(220 + 280*s/MAX)
        ix = int(cx+(R-18)*math.cos(a)); iy = int(cy-(R-18)*math.sin(a))
        ox = int(cx+(R+3) *math.cos(a)); oy = int(cy-(R+3) *math.sin(a))
        pygame.draw.line(surf, C_G2, (ix,iy), (ox,oy), 1)
    # Speed number
    txt(surf, f"{int(speed)}", f_num, C_WHITE, cx, cy+14)
    txt(surf, "km/h",          f_unit, C_G2,   cx, cy+52)

def draw_prox_bar(surf, x, y, w, dist, label, fl, fv):
    MAX = 250
    col = dist_col(dist)
    fill_w = int(w * max(0, min(dist, MAX)) / MAX)
    txt(surf, label, fl, C_G2, x, y+7, "midleft")
    val_s = f"{int(dist)} cm" if dist < 999 else "---"
    txt(surf, val_s, fv, col, x+w, y+7, "midright")
    pygame.draw.rect(surf, C_LINE, (x, y+18, w, 5), border_radius=3)
    if fill_w > 0:
        pygame.draw.rect(surf, col, (x, y+18, fill_w, 5), border_radius=3)

def draw_battery(surf, x, y, w, h, pct, volts, amps, mw, fb, fs):
    col = batt_col(pct)
    pygame.draw.rect(surf, C_LINE, (x, y, w, h), 1, border_radius=4)
    pygame.draw.rect(surf, C_LINE, (x+w, y+h//3, 5, h//3), border_radius=2)
    fw = max(0, int((w-4)*pct/100))
    if fw > 0:
        pygame.draw.rect(surf, col, (x+2, y+2, fw, h-4), border_radius=3)
    txt(surf, f"{pct}%", fb, C_WHITE, x+w//2, y+h//2)
    txt(surf, f"{volts:.2f} V", fs, C_G2, x,       y+h+14, "midleft")
    txt(surf, f"{amps:.2f} A",  fs, C_G2, x+w//2,  y+h+14, "center")
    txt(surf, f"{mw/1000:.1f} W", fs, C_G2, x+w, y+h+14, "midright")

def draw_power_bar(surf, x, y, w, mw, fl, fv):
    MAX_W = 100.0
    frac = min(mw/1000/MAX_W, 1.0)
    pygame.draw.rect(surf, C_LINE, (x, y, w, 7), border_radius=3)
    if frac > 0:
        pygame.draw.rect(surf, C_BLU, (x, y, int(w*frac), 7), border_radius=3)
    txt(surf, "POWER", fl, C_G2, x, y+18, "midleft")
    txt(surf, f"{mw/1000:.1f} W", fv, C_WHITE, x+w, y+18, "midright")

# ══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ══════════════════════════════════════════════════════════════════════════════
def main():
    pygame.init()
    flags  = pygame.NOFRAME if not DEMO_MODE else 0
    screen = pygame.display.set_mode((W, H), flags)
    pygame.display.set_caption("Kart Dashboard")
    pygame.mouse.set_visible(False)

    # Font family — DejaVu (always on Pi / Linux)
    f_sub   = pygame.font.SysFont("dejavusans",  18)
    f_spd   = pygame.font.SysFont("dejavusans",  50, bold=True)
    f_unit  = pygame.font.SysFont("dejavusans",  14)
    f_head  = pygame.font.SysFont("dejavusans",  14, bold=True)
    f_lbl   = pygame.font.SysFont("dejavusans",  12)
    f_val   = pygame.font.SysFont("dejavusans",  12, bold=True)
    f_imu   = pygame.font.SysFont("dejavusans",  20, bold=True)
    f_batt  = pygame.font.SysFont("dejavusans",  16, bold=True)
    f_sm    = pygame.font.SysFont("dejavusans",  11)

    # ── Startup animation ──────────────────────────────────────────────────
    run_startup(screen, f_sub)

    # ── Hardware threads ───────────────────────────────────────────────────
    if HW_AVAILABLE:
        setup_gpio()
        for fn in [thread_speed, thread_imu, thread_ultrasonic,
                   thread_buzzer, thread_camera, thread_power]:
            threading.Thread(target=fn, daemon=True).start()

    clock = pygame.time.Clock()

    # Column X boundaries
    COL_B = 198
    COL_C = 568

    while True:
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                break
            if ev.type == pygame.KEYDOWN and ev.key == pygame.K_ESCAPE:
                if HW_AVAILABLE: GPIO.cleanup()
                pygame.quit(); sys.exit()

        if DEMO_MODE:
            demo_tick()

        with state_lock:
            speed = state["speed_kph"]
            roll  = state["roll_deg"]
            pitch = state["pitch_deg"]
            yaw   = state["yaw_deg"]
            df    = state["dist_front"]
            db    = state["dist_back"]
            bp    = state["batt_pct"]
            bv    = state["batt_v"]
            ba    = state["batt_amps"]
            bmw   = state["batt_mw"]
            cam   = state["camera_frame"]

        # ── Background ────────────────────────────────────────────────────
        screen.fill(C_BG)

        # ── Column dividers ───────────────────────────────────────────────
        vline(screen, COL_B, 18, H-28)
        vline(screen, COL_C, 18, H-28)
        hline(screen, H-28,  0,  W)

        # ═════════════════════════════════════════════════════════════════
        #  COL A  (0 .. COL_B-1)  — Speed + Proximity
        # ═════════════════════════════════════════════════════════════════
        txt(screen, "SPEED", f_head, C_G2, 99, 30)
        draw_speed_arc(screen, 99, 192, 86, speed, f_spd, f_unit)

        hline(screen, 320, 8, COL_B-8)
        draw_prox_bar(screen, 10, 326, 175, df, "FRONT", f_lbl, f_val)
        draw_prox_bar(screen, 10, 358, 175, df, "REAR",  f_lbl, f_val)
        # (fix: back sensor)
        draw_prox_bar(screen, 10, 358, 175, db, "REAR",  f_lbl, f_val)

        # ═════════════════════════════════════════════════════════════════
        #  COL B  (COL_B .. COL_C-1)  — 3D Car + IMU
        # ═════════════════════════════════════════════════════════════════
        car_cx = (COL_B + COL_C) // 2
        txt(screen, "ATTITUDE", f_head, C_G2, car_cx, 30)
        draw_car(screen, car_cx, 196, roll, pitch)

        # Artificial horizon line (roll-tilted)
        hr  = math.radians(roll)
        hlen = 78
        hx1 = int(car_cx - hlen*math.cos(hr)); hy1 = int(196 - hlen*math.sin(hr))
        hx2 = int(car_cx + hlen*math.cos(hr)); hy2 = int(196 + hlen*math.sin(hr))
        pygame.draw.line(screen, (32, 32, 32), (hx1,hy1), (hx2,hy2), 1)

        # IMU readouts
        hline(screen, 328, COL_B+8, COL_C-8)
        step  = (COL_C - COL_B) // 3
        idata = [("ROLL", roll, "deg"), ("PITCH", pitch, "deg"), ("YAW", yaw, "deg")]
        for i, (lbl, val, _) in enumerate(idata):
            ix = COL_B + step*i + step//2
            txt(screen, lbl, f_lbl, C_G2, ix, 342)
            vc  = C_RED if abs(val) > 28 else C_WHITE
            sym = "+" if val >= 0 else ""
            txt(screen, f"{sym}{val:.1f}", f_imu, vc, ix, 364)

        # ═════════════════════════════════════════════════════════════════
        #  COL C  (COL_C .. W-1)  — Camera + Battery + Power
        # ═════════════════════════════════════════════════════════════════
        cam_x = COL_C + 6
        cam_y = 10
        cam_w = W - COL_C - 12
        cam_h = 165

        pygame.draw.rect(screen, C_CARD, (cam_x, cam_y, cam_w, cam_h))
        if cam:
            scaled = pygame.transform.scale(cam, (cam_w, cam_h))
            screen.blit(scaled, (cam_x, cam_y))
        else:
            txt(screen, "NO SIGNAL", f_lbl, C_G2,
                cam_x + cam_w//2, cam_y + cam_h//2)
        txt(screen, "CAM", f_lbl, C_G1, cam_x+5, cam_y+8, "midleft")

        hline(screen, 183, COL_C, W)
        txt(screen, "BATTERY", f_head, C_G2, (COL_C+W)//2, 196)
        draw_battery(screen, COL_C+14, 210, 205, 36,
                     bp, bv, ba, bmw, f_batt, f_sm)

        hline(screen, 280, COL_C, W)
        draw_power_bar(screen, COL_C+14, 292, 205, bmw, f_lbl, f_val)

        # ── Obstacle warning overlay ──────────────────────────────────────
        min_d = min(df, db)
        if min_d < 30:
            alpha = int(50 + 50*abs(math.sin(time.time()*9)))
            ov = pygame.Surface((W, H), pygame.SRCALPHA)
            ov.fill((*C_RED, alpha))
            screen.blit(ov, (0, 0))
            txt(screen, "COLLISION WARNING", f_head, C_WHITE, W//2, H//2)

        # ── Status bar ────────────────────────────────────────────────────
        mode_txt = "LIVE" if HW_AVAILABLE else "DEMO"
        mode_col = C_GRN  if HW_AVAILABLE else C_ORG
        pygame.draw.circle(screen, mode_col, (10, H-14), 4)
        txt(screen, mode_txt,           f_sm, mode_col,  22, H-14, "midleft")
        txt(screen, "KART  DASHBOARD",  f_sm, C_G2,     W//2, H-14)
        txt(screen, time.strftime("%H:%M:%S"), f_sm, C_G2, W-8, H-14, "midright")

        pygame.display.flip()
        clock.tick(30)

    if HW_AVAILABLE:
        GPIO.cleanup()
    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
