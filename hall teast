#!/usr/bin/env python3
"""
Hall Effect Diagnostic — run this on the Pi to test the sensor.
Watch the terminal and pass a magnet over the sensor.

Usage:  python3 hall_test.py
Exit:   Ctrl+C
"""

import RPi.GPIO as GPIO
import time

HALL_PIN = 17   # change if you used a different pin

GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)
GPIO.setup(HALL_PIN, GPIO.IN, pull_up_down=GPIO.PUD_UP)

print("=" * 50)
print(f"  Hall Effect Test — GPIO {HALL_PIN}")
print("=" * 50)
print()

# ── Test 1: Raw pin state ─────────────────────────────────────────────────────
print("TEST 1 — Current pin state:")
state = GPIO.input(HALL_PIN)
print(f"  GPIO {HALL_PIN} reads: {'HIGH (1)' if state else 'LOW (0)'}")
print(f"  Expected with no magnet: HIGH (1)  — pull-up active")
if state == 0:
    print("  ⚠  Pin is LOW with no magnet — sensor may be wired backwards,")
    print("     always triggered, or VCC/GND swapped.")
else:
    print("  ✔  Pin is HIGH with no magnet — correct idle state.")
print()

# ── Test 2: Polling — watch for state changes ─────────────────────────────────
print("TEST 2 — Polling (wave a magnet over sensor now):")
print("  Watching for 10 seconds... Ctrl+C to stop early.\n")

last = GPIO.input(HALL_PIN)
changes = 0
t_start = time.time()

try:
    while time.time() - t_start < 10:
        current = GPIO.input(HALL_PIN)
        if current != last:
            elapsed = time.time() - t_start
            direction = "HIGH→LOW  ← MAGNET DETECTED!" if current == 0 else "LOW→HIGH  (magnet left)"
            print(f"  [{elapsed:5.2f}s]  {direction}")
            if current == 0:
                changes += 1
            last = current
        time.sleep(0.001)
except KeyboardInterrupt:
    pass

print()
if changes == 0:
    print("  ✘  NO magnet detections in polling test.")
    print("     Possible causes:")
    print("     1. Wrong magnet pole — flip the magnet over and try again")
    print("     2. Sensor VCC connected to 5V but is a 3.3V-only model")
    print("     3. Loose wire on VCC, GND, or OUT")
    print("     4. Sensor is digital type — needs magnet within ~5mm")
    print("     5. GPIO 17 pin damaged — try GPIO 27 and change HALL_PIN")
else:
    print(f"  ✔  {changes} magnet detection(s) — polling works!")

print()

# ── Test 3: Interrupt detection ───────────────────────────────────────────────
print("TEST 3 — Interrupt detection (wave magnet again):")
print("  Watching for 10 seconds...\n")

count = [0]

def cb(ch):
    count[0] += 1
    print(f"  *** INTERRUPT FIRED — total: {count[0]} ***")

try:
    GPIO.remove_event_detect(HALL_PIN)
except Exception:
    pass

try:
    GPIO.add_event_detect(HALL_PIN, GPIO.FALLING, callback=cb, bouncetime=2)
    print("  Interrupt registered OK. Wave the magnet...\n")
    time.sleep(10)
except RuntimeError as e:
    print(f"  ✘  Could not register interrupt: {e}")
    print("     Try rebooting the Pi — GPIO may be stuck from previous run.")

print()
if count[0] == 0:
    print("  ✘  Interrupt never fired — but polling may have worked.")
    print("     This means GPIO edge detection is broken on this pin.")
    print("     Try:  sudo pigpiod  and use pigpio library instead.")
elif count[0] > 0:
    print(f"  ✔  Interrupt worked — {count[0]} triggers detected!")
    print("     The dashboard hall sensor code should work.")
    print("     If speed still shows 0: check WHEEL_CIRC_M value.")

print()
print("=" * 50)
GPIO.cleanup()
