#  CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
I2C_BUS        = 1

# INA219 — calibration
# INA219_CAL_VAL and INA219_CUR_LSB depend on your shunt resistor.
# Most cheap breakout boards use a 0.1-ohm shunt:
#   For +-3.2A range:  CAL=4096,  CUR_LSB=0.0001  (100 uA/bit)
#   For +-6.4A range:  CAL=2048,  CUR_LSB=0.0002  (200 uA/bit)
#   For +-32A range:   CAL=409,   CUR_LSB=0.001   (1 mA/bit)  <- use for kart motors
# If your amps reading looks wrong, adjust CUR_LSB until it matches a clamp meter.
INA219_ADDR    = 0x40
INA219_REG_CFG = 0x00
INA219_REG_BUS = 0x02
INA219_REG_CUR = 0x04
INA219_REG_CAL = 0x05
INA219_CAL_VAL = 4096          # +-3.2A range, 0.1-ohm shunt
INA219_CUR_LSB = 0.0001        # 100 uA per bit

# Battery pack — 2x 12V Lead Acid in series (24V nominal)
# Lead acid voltage curve:
#   Full charge (resting):  28.0V  (14.0V x 2)
#   Fully charged (float):  27.2V  (13.6V x 2)
#   Nominal:                24.0V  (12.0V x 2)
#   Low (stop using):       22.0V  (11.0V x 2)
#   Dead (damaged):         20.0V  (10.0V x 2)
BATT_FULL_V    = 27.2        # 2x 12V lead acid fully charged
BATT_EMPTY_V   = 22.0        # 2x 12V lead acid low — stop here to protect battery

# GPIO (BCM)
HALL_PIN       = 17
MAGNET_COUNT   = 4
TRIG_FRONT     = 23
ECHO_FRONT     = 24
TRIG_BACK      = 27
ECHO_BACK      = 22
BUZZER_PIN     = 18

WHEEL_CIRC_M   = 1.117       # 14 inch rear wheel
CAMERA_INDEX   = 0

# ══════════════════════════════════════════════════════════════════════════════
#  SHARED STATE
# ══════════════════════════════════════════════════════════════════════════════
state = {
    "speed_kph":      0.0,
    "miles_traveled": 0.0,   # odometer in miles
    "dist_front":     999,
    "dist_back":      999,
    "batt_pct":       100,
    "batt_v":         12.6,
    "batt_amps":      0.0,
    "batt_mw":        0.0,
    "camera_frame":   None,
}
state_lock = threading.Lock()

# ══════════════════════════════════════════════════════════════════════════════
#  INA219 DRIVER
# ══════════════════════════════════════════════════════════════════════════════
class INA219:
    def __init__(self, bus, addr=INA219_ADDR):
        self.bus  = bus
        self.addr = addr
        self._write(INA219_REG_CAL, INA219_CAL_VAL)
        self._write(INA219_REG_CFG, 0x1FFF)  # 32V, 320mV shunt, 12-bit, continuous

    def _write(self, reg, val):
        self.bus.write_i2c_block_data(self.addr, reg,
                                      [(val >> 8) & 0xFF, val & 0xFF])

    def _read(self, reg):
        d = self.bus.read_i2c_block_data(self.addr, reg, 2)
        return (d[0] << 8) | d[1]

    def voltage(self):
        return (self._read(INA219_REG_BUS) >> 3) * 0.004

    def current_A(self):
        raw = self._read(INA219_REG_CUR)
        if raw > 32767: raw -= 65536
        return raw * INA219_CUR_LSB

    def power_mW(self):
        return self._read(0x03) * 2.0

# ══════════════════════════════════════════════════════════════════════════════
#  GPIO SETUP
# ══════════════════════════════════════════════════════════════════════════════
def setup_gpio():
    GPIO.setmode(GPIO.BCM)
    GPIO.setwarnings(False)
    GPIO.setup(HALL_PIN,   GPIO.IN,  pull_up_down=GPIO.PUD_UP)
    GPIO.setup(TRIG_FRONT, GPIO.OUT); GPIO.output(TRIG_FRONT, False)
    GPIO.setup(ECHO_FRONT, GPIO.IN)
    GPIO.setup(TRIG_BACK,  GPIO.OUT); GPIO.output(TRIG_BACK,  False)
    GPIO.setup(ECHO_BACK,  GPIO.IN)
    GPIO.setup(BUZZER_PIN, GPIO.OUT)

def _ultrasonic_single(trig, echo):
    """One raw reading. Returns cm or 999 on timeout."""
    try:
        # Ensure trig is low before pulse
        GPIO.output(trig, False)
        time.sleep(0.002)
        GPIO.output(trig, True)
        time.sleep(1e-5)
        GPIO.output(trig, False)
        t0 = time.time()
        while GPIO.input(echo) == 0:
            if time.time() - t0 > 0.06: return 999   # wait for echo start
        t1 = time.time()
        while GPIO.input(echo) == 1:
            if time.time() - t1 > 0.06: return 999   # wait for echo end
        dist = (time.time() - t1) * 17150
        # Reject physically impossible readings
        if dist < 2 or dist > 400:
            return 999
        return round(dist, 1)
    except Exception:
        return 999

def _ultrasonic(trig, echo, samples=3):
    """Median of N readings to filter out spikes."""
    readings = []
    for _ in range(samples):
        r = _ultrasonic_single(trig, echo)
        readings.append(r)
        time.sleep(0.015)   # let echo fully clear before next ping
    valid = [r for r in readings if r < 999]
    if not valid:
        return 999
    valid.sort()
    return valid[len(valid)//2]   # median

# ══════════════════════════════════════════════════════════════════════════════
#  SENSOR THREADS
# ══════════════════════════════════════════════════════════════════════════════
def thread_speed():
    """Poll-based hall effect — same method as hall_test.py which is confirmed working."""
    last_state  = 1        # HIGH = no magnet (pull-up)
    pulse_times = []
    # Each pulse = 1/MAGNET_COUNT of a wheel revolution
    meters_per_pulse = WHEEL_CIRC_M / MAGNET_COUNT
    miles_per_pulse  = meters_per_pulse / 1609.344

    print("[Hall] Starting poll-based speed detection on GPIO", HALL_PIN)

    while True:
        try:
            val = GPIO.input(HALL_PIN)

            # Detect HIGH -> LOW transition (magnet passing)
            if val == 0 and last_state == 1:
                now = time.time()
                pulse_times.append(now)
                if len(pulse_times) > MAGNET_COUNT * 4:
                    pulse_times.pop(0)
                # Add distance for this pulse
                with state_lock:
                    state["miles_traveled"] += miles_per_pulse

            last_state = val

            # Calculate speed
            now = time.time()
            recent = [t for t in pulse_times if now - t < 1.5]
            if len(recent) >= 2:
                ivs = [recent[i+1]-recent[i] for i in range(len(recent)-1)]
                avg  = sum(ivs) / len(ivs)
                if avg > 0:
                    rps = 1.0 / (avg * MAGNET_COUNT)
                    kph = rps * WHEEL_CIRC_M * 3.6
                    with state_lock:
                        state["speed_kph"] = min(kph, 150.0)
            else:
                if now - (pulse_times[-1] if pulse_times else 0) > 1.5:
                    with state_lock:
                        state["speed_kph"] = 0.0

            time.sleep(0.001)

        except Exception as e:
            print(f"[Hall] error: {e}")
            time.sleep(0.1)

def thread_ultrasonic():
    while True:
        df = _ultrasonic(TRIG_FRONT, ECHO_FRONT)
        time.sleep(0.05)        # let ultrasound dissipate before firing second sensor
        db = _ultrasonic(TRIG_BACK,  ECHO_BACK)
        with state_lock:
            state["dist_front"] = df
            state["dist_back"]  = db
        time.sleep(0.05)

def thread_buzzer():
    """PWM tone buzzer for passive buzzers — beeps faster the closer the object."""
    pwm = GPIO.PWM(BUZZER_PIN, 2000)   # 2kHz tone — good beep pitch
    pwm.start(0)                        # start silent

    while True:
        try:
            with state_lock:
                d = min(state["dist_front"], state["dist_back"])

            if d < 200:
                # Beep period: 800ms at 200cm → 80ms at 10cm
                period = max(0.08, d / 250.0)
                beep_on  = period * 0.4
                beep_off = period * 0.6

                pwm.ChangeDutyCycle(50)   # 50% duty = loudest tone
                time.sleep(beep_on)
                pwm.ChangeDutyCycle(0)    # silent
                time.sleep(beep_off)
            else:
                pwm.ChangeDutyCycle(0)
                time.sleep(0.1)

        except Exception:
            pwm.ChangeDutyCycle(0)
            time.sleep(0.1)

def thread_camera():
    cap = None
    for backend in [cv2.CAP_V4L2, cv2.CAP_ANY]:
        try:
            c = cv2.VideoCapture(CAMERA_INDEX, backend)
            if c.isOpened():
                cap = c
                print(f"[CAM] Opened (backend {backend})")
                break
            c.release()
        except Exception:
            pass
    if cap is None:
        print("[CAM] No camera found.")
        return
    cap.set(cv2.CAP_PROP_FRAME_WIDTH,  320)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 240)
    cap.set(cv2.CAP_PROP_BUFFERSIZE,   1)
    while True:
        try:
            ret, frame = cap.read()
            if ret:
                rgb  = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                surf = pygame.surfarray.make_surface(rgb.swapaxes(0, 1))
                with state_lock:
                    state["camera_frame"] = surf
            else:
                time.sleep(0.1)
        except Exception as e:
            print(f"[CAM] error: {e}")
            time.sleep(0.5)
        time.sleep(0.033)

def thread_power():
    # Lead acid 24V (2x 12V series) voltage → % lookup table
    # Based on real lead acid discharge curve (resting voltage)
    LEAD_ACID_CURVE = [
        (27.2, 100), (26.8, 95), (26.4, 90), (26.0, 85),
        (25.6, 75),  (25.2, 65), (24.8, 55), (24.4, 45),
        (24.0, 35),  (23.6, 25), (23.2, 15), (22.8, 8),
        (22.4, 4),   (22.0, 0),
    ]

    def volts_to_pct(v):
        # Above max
        if v >= LEAD_ACID_CURVE[0][0]:
            return 100
        # Below min
        if v <= LEAD_ACID_CURVE[-1][0]:
            return 0
        # Interpolate between two nearest points
        for i in range(len(LEAD_ACID_CURVE) - 1):
            v1, p1 = LEAD_ACID_CURVE[i]
            v2, p2 = LEAD_ACID_CURVE[i+1]
            if v2 <= v <= v1:
                t = (v - v2) / (v1 - v2)
                return int(p2 + t * (p1 - p2))
        return 0

    bus = None; ina = None
    for attempt in range(10):
        try:
            bus = smbus2.SMBus(I2C_BUS)
            ina = INA219(bus)
            print(f"[INA219] OK at 0x{INA219_ADDR:02X}")
            break
        except Exception as e:
            print(f"[INA219] Init attempt {attempt+1} failed: {e}. Retrying in 2s...")
            time.sleep(2)
    if ina is None:
        print("[INA219] Not found. Battery disabled.")
        return
    while True:
        try:
            v   = ina.voltage()
            a   = ina.current_A()
            mw  = ina.power_mW()
            pct = volts_to_pct(v)
            with state_lock:
                state["batt_v"]    = v
                state["batt_amps"] = a
                state["batt_mw"]   = mw
                state["batt_pct"]  = pct
        except Exception as e:
            print(f"[INA219] Read error: {e}. Re-init...")
            time.sleep(1)
            try:
                bus = smbus2.SMBus(I2C_BUS)
                ina = INA219(bus)
            except Exception:
                pass
        time.sleep(0.4)

# ══════════════════════════════════════════════════════════════════════════════
#  DEMO SIMULATION
# ══════════════════════════════════════════════════════════════════════════════
_dt = 0.0
def demo_tick():
    global _dt; _dt += 0.025
    with state_lock:
        spd_kph = 55 + 40*math.sin(_dt*0.28)
        state["speed_kph"]      = spd_kph
        state["dist_front"]     = max(8,  160 + 130*math.sin(_dt*0.62))
        state["dist_back"]      = max(8,  190 + 100*math.sin(_dt*0.51+2))
        state["batt_pct"]       = int(68 + 18*math.sin(_dt*0.08))
        state["batt_v"]         = 11.2 + 1.2*math.sin(_dt*0.08)
        state["batt_amps"]      = abs(6.5*math.sin(_dt*0.19))
        state["batt_mw"]        = state["batt_v"] * state["batt_amps"] * 1000
        # Accumulate demo miles (speed * time_step converted to miles)
        mph = spd_kph * 0.621371
        state["miles_traveled"] += mph * (0.025 / 3600.0)

# ══════════════════════════════════════════════════════════════════════════════
#  PALETTE  — Tesla: near-black, white, red accent only
# ══════════════════════════════════════════════════════════════════════════════
W, H = 1200, 720

C_BG   = (  7,   7,   7)
C_CARD = ( 16,  16,  16)
C_LINE = ( 36,  36,  36)
C_WHT  = (255, 255, 255)
C_G1   = (210, 210, 210)
C_G2   = (160, 160, 160)
C_RED  = (225,  55,  42)
C_ORG  = (230, 140,  20)
C_GRN  = ( 90, 205,  90)
C_BLU  = ( 75, 155, 255)

def lerp_c(a, b, t):
    return tuple(int(a[i]+(b[i]-a[i])*t) for i in range(3))

def dist_col(d):
    if d <  30: return C_RED
    if d <  80: return C_ORG
    if d < 160: return (200, 200, 55)
    return C_GRN

def batt_col(p):
    if p < 20: return C_RED
    if p < 40: return C_ORG
    return C_GRN

def txt(surf, text, font, color, x, y, anchor="center"):
    img = font.render(str(text), True, color)
    r   = img.get_rect()
    setattr(r, anchor, (x, y))
    surf.blit(img, r)

def vline(s, x, y1, y2): pygame.draw.line(s, C_LINE, (x,y1), (x,y2), 1)
def hline(s, y, x1, x2): pygame.draw.line(s, C_LINE, (x1,y), (x2,y), 1)

# ══════════════════════════════════════════════════════════════════════════════
#  STARTUP ANIMATION
#  0.0 – 1.6s  : "C" arc draws itself with glowing lead dot
#  1.6 – 3.2s  : "C" pulses; "COSMOS BUILDERS" types in letter by letter
#  3.2 – 4.6s  : tagline "KART DASHBOARD" fades in below
#  4.6 – 5.8s  : everything fades to black → dashboard
# ══════════════════════════════════════════════════════════════════════════════
def run_startup(screen, f_sub):
    clock   = pygame.time.Clock()
    t0      = time.time()
    CX      = W // 2
    CY      = H // 2 - 30          # slightly above centre to leave room for text
    R       = 100
    TOTAL   = 5.8

    # Font sizes for startup only
    f_brand = pygame.font.SysFont("dejavusans", 34, bold=True)
    f_tag   = pygame.font.SysFont("dejavusans", 15)

    START_A = math.radians(32)
    END_A   = math.radians(328)
    BRAND   = "COSMOS BUILDERS"

    def glow_circle(surf, cx, cy, rr, col, alpha):
        gs = pygame.Surface((rr*2+2, rr*2+2), pygame.SRCALPHA)
        pygame.draw.circle(gs, (*col, alpha), (rr+1, rr+1), rr)
        surf.blit(gs, (cx-rr-1, cy-rr-1))

    def draw_C(surf, progress, brightness=1.0):
        total   = END_A - START_A
        draw_to = START_A + total * min(progress, 1.0)
        rect    = pygame.Rect(CX-R, CY-R, R*2, R*2)
        # Glow layers
        for thick, am in [(30,0.03),(20,0.09),(12,0.25),(6,0.55),(2,1.00)]:
            col = lerp_c(C_G2, C_WHT, am * brightness)
            a1, a2 = -draw_to, -START_A
            if abs(a2-a1) > 0.02:
                pygame.draw.arc(surf, col, rect, a1, a2, thick)
        # Glowing lead dot
        if progress > 0.01 and progress < 1.02:
            dx = int(CX + R * math.cos(-draw_to))
            dy = int(CY + R * math.sin(-draw_to))
            for rr, aa in [(28,15),(18,45),(10,100),(5,210)]:
                glow_circle(surf, dx, dy, rr, C_WHT, aa)

    def draw_brand(surf, progress):
        """Type COSMOS BUILDERS letter by letter, each glowing in."""
        n_chars = len(BRAND)
        chars_to_show = min(n_chars, int(progress * (n_chars + 2)))
        displayed = BRAND[:chars_to_show]
        # Measure full string width for centering
        full_w = f_brand.size(BRAND)[0]
        x_start = CX - full_w // 2
        x = x_start
        for i, ch in enumerate(displayed):
            char_age = progress * (n_chars + 2) - i   # how long this char has been visible
            alpha    = min(255, int(char_age * 180))
            ci       = f_brand.render(ch, True, C_WHT)
            ci.set_alpha(alpha)
            surf.blit(ci, (x, CY + R + 28))
            x += f_brand.size(ch)[0]

    while True:
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN and ev.key == pygame.K_ESCAPE:
                return

        t = time.time() - t0
        if t > TOTAL:
            return

        screen.fill(C_BG)

        # ── Phase 1: C draws in ──────────────────────────────────────────
        if t < 1.6:
            p = t / 1.6
            ease = p * p * (3 - 2*p)   # smoothstep
            draw_C(screen, ease)

        # ── Phase 2: C pulses + COSMOS BUILDERS types in ─────────────────
        elif t < 3.2:
            sub = (t - 1.6) / 1.6
            pulse = 0.85 + 0.15 * math.sin(t * 7)
            draw_C(screen, 1.0, pulse)
            draw_brand(screen, sub)

        # ── Phase 3: tagline fades in ─────────────────────────────────────
        elif t < 4.6:
            sub  = (t - 3.2) / 1.4
            draw_C(screen, 1.0, 0.9)
            draw_brand(screen, 1.0)
            fa = min(255, int(sub * 255))
            ti = f_tag.render("KART DASHBOARD", True, C_G2)
            ti.set_alpha(fa)
            screen.blit(ti, ti.get_rect(center=(CX, CY + R + 72)))

        # ── Phase 4: fade to black ────────────────────────────────────────
        else:
            fade_t = (t - 4.6) / 1.2
            bright = 1.0 - fade_t
            draw_C(screen, 1.0, bright)
            # Fade brand text
            draw_brand(screen, 1.0)
            full_w = f_brand.size(BRAND)[0]
            # Darken with overlay
            fade = pygame.Surface((W, H))
            fade.fill(C_BG)
            fade.set_alpha(int(fade_t * 255))
            screen.blit(fade, (0, 0))

        pygame.display.flip()
        clock.tick(60)

# ══════════════════════════════════════════════════════════════════════════════
#  UI WIDGETS
# ══════════════════════════════════════════════════════════════════════════════
def draw_speed_arc(surf, cx, cy, R, speed_kph, f_num, f_unit):
    speed_mph = speed_kph * 0.621371
    MAX_MPH   = 80    # arc goes to 80 mph
    span      = math.radians(280)
    fill      = span * min(speed_mph, MAX_MPH) / MAX_MPH
    # Track
    pygame.draw.arc(surf, C_LINE,
        pygame.Rect(cx-R, cy-R, R*2, R*2),
        math.radians(220), math.radians(500), 7)
    # Coloured fill
    if fill > 0.01:
        col = lerp_c(C_GRN, C_RED, min(speed_mph, MAX_MPH) / MAX_MPH)
        pygame.draw.arc(surf, col,
            pygame.Rect(cx-R+2, cy-R+2, (R-2)*2, (R-2)*2),
            math.radians(220), math.radians(220)+fill, 7)
    # Tick marks every 10 mph
    for s in range(0, MAX_MPH+1, 10):
        a  = math.radians(220 + 280*s/MAX_MPH)
        ix = int(cx+(R-18)*math.cos(a)); iy = int(cy-(R-18)*math.sin(a))
        ox = int(cx+(R+4) *math.cos(a)); oy = int(cy-(R+4) *math.sin(a))
        pygame.draw.line(surf, C_G2, (ix,iy),(ox,oy), 1)
    # Main: mph (big)
    txt(surf, f"{int(speed_mph)}", f_num,  C_WHT, cx, cy+8)
    txt(surf, "mph",               f_unit, C_G1,  cx, cy+48)
    # Secondary: km/h (smaller, dimmer)
    txt(surf, f"{int(speed_kph)} km/h", f_unit, C_G2, cx, cy+64)

def draw_battery(surf, x, y, w, h, pct, volts, amps, mw, fb, fs):
    col = batt_col(pct)
    pygame.draw.rect(surf, C_LINE, (x,y,w,h), 1, border_radius=4)
    pygame.draw.rect(surf, C_LINE, (x+w, y+h//3, 5, h//3), border_radius=2)
    fw = max(0, int((w-4)*pct/100))
    if fw > 0:
        pygame.draw.rect(surf, col, (x+2,y+2,fw,h-4), border_radius=3)
    txt(surf, f"{pct}%",         fb, C_WHT, x+w//2,  y+h//2)
    txt(surf, f"{volts:.2f} V",  fs, C_G2,  x,        y+h+14, "midleft")
    txt(surf, f"{amps:.2f} A",   fs, C_G2,  x+w//2,   y+h+14, "center")
    txt(surf, f"{mw/1000:.1f} W",fs, C_G2,  x+w,      y+h+14, "midright")

def draw_radar(surf, cx, cy, r, dist_front, dist_back, f_val):
    """
    Clean sonar-style radar:
    - Concentric distance rings with labels
    - Kart silhouette in centre
    - Obstacle bars sweep inward from edge as objects get closer
    - Glowing threat zone when < 50cm
    """
    MAX   = 250   # cm = edge of radar
    now   = time.time()

    # ── Clipped drawing area (circle mask) ───────────────────────────────────
    radar_surf = pygame.Surface((r*2+2, r*2+2), pygame.SRCALPHA)
    rs = r + 1   # local centre of radar_surf

    # Background
    pygame.draw.circle(radar_surf, (10, 12, 16, 255), (rs, rs), r)

    # Concentric rings at 25%, 50%, 75%
    ring_labels = [(r*1//4, "190"), (r*2//4, "125"), (r*3//4, "60")]
    for rr, lbl in ring_labels:
        pygame.draw.circle(radar_surf, (40, 45, 55, 180), (rs, rs), rr, 1)

    # Cross-hair lines (dim)
    pygame.draw.line(radar_surf, (35, 40, 50, 180),
                     (rs, rs-r), (rs, rs+r), 1)
    pygame.draw.line(radar_surf, (35, 40, 50, 180),
                     (rs-r, rs), (rs+r, rs), 1)

    # Diagonal guides
    d = int(r * 0.707)
    pygame.draw.line(radar_surf, (25, 28, 35, 120),
                     (rs-d, rs-d), (rs+d, rs+d), 1)
    pygame.draw.line(radar_surf, (25, 28, 35, 120),
                     (rs+d, rs-d), (rs-d, rs+d), 1)

    # ── Obstacle threat zones ─────────────────────────────────────────────────
    def draw_threat(dist, is_front):
        if dist >= MAX:
            return
        frac     = 1.0 - dist / MAX        # 0=far, 1=very close
        col      = dist_col(dist)
        # How far from centre the obstacle dot is (close = near centre)
        dot_dist = int(r * dist / MAX)
        dot_y    = rs - dot_dist if is_front else rs + dot_dist

        # Filled sweep wedge from edge inward — brighter = closer
        wedge_alpha = int(30 + frac * 80)
        half_ang    = math.radians(25 + frac * 20)   # wider wedge when closer
        base_ang    = math.pi / 2 if is_front else 3 * math.pi / 2

        pts = [(rs, rs)]
        steps = 16
        for i in range(steps + 1):
            a = base_ang - half_ang + (2 * half_ang * i / steps)
            px = rs + int(r * math.cos(a))
            py = rs - int(r * math.sin(a))
            pts.append((px, py))
        ws = pygame.Surface((r*2+2, r*2+2), pygame.SRCALPHA)
        pygame.draw.polygon(ws, (*col, wedge_alpha), pts)
        # Clip to circle
        pygame.draw.circle(ws, (0,0,0,0), (rs,rs), r, r+2)
        radar_surf.blit(ws, (0, 0))

        # Obstacle line across the wedge at the distance
        line_half = int((r - dot_dist) * math.sin(half_ang) * 0.85)
        lx1 = rs - line_half
        lx2 = rs + line_half
        ly  = dot_y
        line_thick = max(1, int(frac * 3))
        pygame.draw.line(radar_surf, col, (lx1, ly), (lx2, ly), line_thick)

        # Glowing dot at obstacle
        dot_r = max(3, int(frac * 7))
        pygame.draw.circle(radar_surf, col, (rs, dot_y), dot_r)

        # Pulse ring when very close
        if dist < 60:
            pulse = int(dot_r + 5 * abs(math.sin(now * 7)))
            ps = pygame.Surface((pulse*2+2, pulse*2+2), pygame.SRCALPHA)
            pygame.draw.circle(ps, (*col, 90), (pulse+1, pulse+1), pulse, 2)
            radar_surf.blit(ps, (rs-pulse-1, dot_y-pulse-1))

    draw_threat(dist_front, True)
    draw_threat(dist_back,  False)

    # ── Outer ring border ─────────────────────────────────────────────────────
    pygame.draw.circle(radar_surf, (55, 62, 78, 255), (rs, rs), r, 1)

    # ── Kart body in centre ───────────────────────────────────────────────────
    kw, kh = 10, 18
    kart_rect = pygame.Rect(rs - kw//2, rs - kh//2, kw, kh)
    pygame.draw.rect(radar_surf, (180, 185, 195, 255), kart_rect, border_radius=3)
    # Front arrow
    pygame.draw.polygon(radar_surf, (255, 255, 255, 220), [
        (rs,      rs - kh//2 - 5),
        (rs - 4,  rs - kh//2 + 2),
        (rs + 4,  rs - kh//2 + 2),
    ])

    # ── Blit radar onto main surface ──────────────────────────────────────────
    surf.blit(radar_surf, (cx - r - 1, cy - r - 1))

    # ── Distance labels outside circle (on main surf) ─────────────────────────
    f_tiny = pygame.font.SysFont("dejavusans", 9)
    # FRONT label + value
    df_col = dist_col(dist_front)
    df_str = f"{int(dist_front)} cm" if dist_front < MAX else "clear"
    txt(surf, "FWD", f_tiny, C_G2,   cx,        cy - r - 12, "center")
    txt(surf, df_str, f_val, df_col, cx,        cy - r - 2,  "center")
    # REAR label + value
    db_col = dist_col(dist_back)
    db_str = f"{int(dist_back)} cm"  if dist_back  < MAX else "clear"
    txt(surf, "REV", f_tiny, C_G2,   cx,        cy + r + 4,  "center")
    txt(surf, db_str, f_val, db_col, cx,        cy + r + 14, "center")

def draw_power_bar(surf, x, y, w, mw, fl, fv):
    MAX_W = 100.0
    frac  = min(mw/1000/MAX_W, 1.0)
    pygame.draw.rect(surf, C_LINE, (x,y,w,7), border_radius=3)
    if frac > 0:
        pygame.draw.rect(surf, C_BLU, (x,y,int(w*frac),7), border_radius=3)
    txt(surf, "POWER",            fl, C_G1,  x,   y+18, "midleft")
    txt(surf, f"{mw/1000:.1f} W", fv, C_WHT, x+w, y+18, "midright")

# ══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ══════════════════════════════════════════════════════════════════════════════
def main():
    pygame.init()
    flags  = pygame.NOFRAME if not DEMO_MODE else 0
    screen = pygame.display.set_mode((W, H), flags)
    pygame.display.set_caption("Kart Dashboard")
    pygame.mouse.set_visible(False)

    f_sub  = pygame.font.SysFont("dejavusans", 20)
    f_spd  = pygame.font.SysFont("dejavusans", 72, bold=True)
    f_unit = pygame.font.SysFont("dejavusans", 18)
    f_head = pygame.font.SysFont("dejavusans", 16, bold=True)
    f_lbl  = pygame.font.SysFont("dejavusans", 15)
    f_val  = pygame.font.SysFont("dejavusans", 15, bold=True)
    f_batt = pygame.font.SysFont("dejavusans", 20, bold=True)
    f_sm   = pygame.font.SysFont("dejavusans", 13)

    # Startup animation
    run_startup(screen, f_sub)

    # Hardware threads
    if HW_AVAILABLE:
        setup_gpio()
        for fn in [thread_speed, thread_ultrasonic, thread_buzzer,
                   thread_camera, thread_power]:
            threading.Thread(target=fn, daemon=True).start()

    clock = pygame.time.Clock()

    # Layout: Left | Centre | Right
    # Left:   0–299   — Speedometer + proximity + odometer
    # Centre: 300–849 — Camera (big)
    # Right:  850–1199 — Radar + Battery + Power
    COL_C = 300
    COL_R = 850

    # Exit button rect (top-right corner, touchable)
    EXIT_BTN = pygame.Rect(W - 70, 8, 62, 32)

    while True:
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                if HW_AVAILABLE: GPIO.cleanup()
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN and ev.key == pygame.K_ESCAPE:
                if HW_AVAILABLE: GPIO.cleanup()
                pygame.quit(); sys.exit()
            if ev.type == pygame.MOUSEBUTTONDOWN:
                if EXIT_BTN.collidepoint(ev.pos):
                    if HW_AVAILABLE: GPIO.cleanup()
                    pygame.quit(); sys.exit()

        if DEMO_MODE: demo_tick()

        with state_lock:
            speed  = state["speed_kph"]
            miles  = state["miles_traveled"]
            df     = state["dist_front"]
            db     = state["dist_back"]
            bp     = state["batt_pct"]
            bv     = state["batt_v"]
            ba     = state["batt_amps"]
            bmw    = state["batt_mw"]
            cam    = state["camera_frame"]

        # ── Background ────────────────────────────────────────────────────
        screen.fill(C_BG)

        # ── Column dividers ───────────────────────────────────────────────
        vline(screen, COL_C, 18, H-36)
        vline(screen, COL_R, 18, H-36)
        hline(screen, H-36,  0,  W)

        # ══════════════════════════════════════════════════════════════════
        #  LEFT — Speedometer
        # ══════════════════════════════════════════════════════════════════
        spd_cx = COL_C // 2
        txt(screen, "SPEED", f_head, C_G1, spd_cx, 28)
        draw_speed_arc(screen, spd_cx, 240, 130, speed, f_spd, f_unit)

        # Front / rear distance bars
        hline(screen, 430, 8, COL_C-8)
        bar_w = COL_C - 24

        df_frac = max(0, min(df, 250)) / 250
        df_col  = dist_col(df)
        txt(screen, "FRONT", f_lbl, C_G1, 14, 448, "midleft")
        ds_f = f"{int(df)} cm" if df < 999 else "---"
        txt(screen, ds_f, f_val, df_col, COL_C-14, 448, "midright")
        pygame.draw.rect(screen, C_LINE, (14, 460, bar_w, 6), border_radius=3)
        if df_frac > 0:
            pygame.draw.rect(screen, df_col, (14, 460, int(bar_w*df_frac), 6), border_radius=3)

        db_frac = max(0, min(db, 250)) / 250
        db_col  = dist_col(db)
        txt(screen, "REAR", f_lbl, C_G1, 14, 484, "midleft")
        ds_b = f"{int(db)} cm" if db < 999 else "---"
        txt(screen, ds_b, f_val, db_col, COL_C-14, 484, "midright")
        pygame.draw.rect(screen, C_LINE, (14, 496, bar_w, 6), border_radius=3)
        if db_frac > 0:
            pygame.draw.rect(screen, db_col, (14, 496, int(bar_w*db_frac), 6), border_radius=3)

        # Odometer
        hline(screen, 520, 8, COL_C-8)
        txt(screen, "TRIP", f_lbl, C_G1, 14, 540, "midleft")
        txt(screen, f"{miles:.3f} mi", f_val, C_WHT, COL_C-14, 540, "midright")

        # ══════════════════════════════════════════════════════════════════
        #  CENTRE — Camera feed (large)
        # ══════════════════════════════════════════════════════════════════
        cam_x = COL_C + 6
        cam_y = 10
        cam_w = COL_R - COL_C - 12
        cam_h = H - 36 - cam_y - 6

        pygame.draw.rect(screen, C_CARD, (cam_x, cam_y, cam_w, cam_h))
        if cam:
            scaled = pygame.transform.scale(cam, (cam_w, cam_h))
            screen.blit(scaled, (cam_x, cam_y))
            txt(screen, "CAM", f_lbl, C_G1, cam_x+8, cam_y+12, "midleft")
        else:
            txt(screen, "NO SIGNAL", f_lbl, C_G2, cam_x+cam_w//2, cam_y+cam_h//2)

        # ══════════════════════════════════════════════════════════════════
        #  RIGHT — Radar + Battery + Power
        # ══════════════════════════════════════════════════════════════════
        right_cx = (COL_R + W) // 2
        right_w  = W - COL_R

        txt(screen, "RADAR", f_head, C_G1, right_cx, 22)
        radar_r  = 110
        radar_cy = 36 + radar_r + 4
        draw_radar(screen, right_cx, radar_cy, radar_r, df, db, f_val)

        batt_top = radar_cy + radar_r + 22
        hline(screen, batt_top, COL_R+6, W-6)
        txt(screen, "BATTERY", f_head, C_G1, right_cx, batt_top+14)
        batt_x = COL_R + 14
        batt_w = right_w - 28
        draw_battery(screen, batt_x, batt_top+28, batt_w, 42,
                     bp, bv, ba, bmw, f_batt, f_sm)

        pw_top = batt_top + 96
        hline(screen, pw_top, COL_R+6, W-6)
        draw_power_bar(screen, batt_x, pw_top+10, batt_w, bmw, f_lbl, f_val)

        # ── Collision overlay ─────────────────────────────────────────────
        front_warn = df < 30
        back_warn  = db < 30
        if front_warn or back_warn:
            alpha = int(50 + 50*abs(math.sin(time.time()*9)))
            ov = pygame.Surface((W,H), pygame.SRCALPHA)
            ov.fill((*C_RED, alpha))
            screen.blit(ov, (0,0))
            if front_warn and back_warn:
                warn_txt = "⚠  FRONT & REAR COLLISION WARNING"
            elif front_warn:
                warn_txt = "⚠  FRONT COLLISION WARNING"
            else:
                warn_txt = "⚠  REAR COLLISION WARNING"
            txt(screen, warn_txt, f_head, C_WHT, W//2, H//2 - 14)
            txt(screen, f"FRONT: {int(df)} cm    REAR: {int(db)} cm",
                f_sm, C_WHT, W//2, H//2 + 14)

        # ── Exit button (touchscreen) ──────────────────────────────────────
        pygame.draw.rect(screen, (40, 18, 18), EXIT_BTN, border_radius=6)
        pygame.draw.rect(screen, C_RED,        EXIT_BTN, 1, border_radius=6)
        txt(screen, "EXIT", f_sm, C_RED, EXIT_BTN.centerx, EXIT_BTN.centery)

        # ── Status bar ────────────────────────────────────────────────────
        mode_txt = "LIVE" if HW_AVAILABLE else "DEMO"
        mode_col = C_GRN  if HW_AVAILABLE else C_ORG
        pygame.draw.circle(screen, mode_col, (12, H-18), 5)
        txt(screen, mode_txt,                  f_sm, mode_col, 26,  H-18, "midleft")
        txt(screen, "COSMOS BUILDERS  —  KART DASHBOARD", f_sm, C_G1, W//2, H-18)
        txt(screen, time.strftime("%H:%M:%S"), f_sm, C_G1,    W-8, H-18, "midright")

        pygame.display.flip()
        pygame.mouse.set_visible(True)
        clock.tick(30)

    if HW_AVAILABLE:
        GPIO.cleanup()
    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
